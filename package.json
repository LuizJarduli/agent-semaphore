{
  "name": "signalme",
  "version": "1.0.0",
  "description": "Multiplatform agent semaphore tool playing audio alerts and managing lifecycle hooks",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "signalme": "./dist/index.js"
  },
  "scripts": {
    "start": "npx tsx ./src/index.ts",
    "build": "tsc -p tsconfig.json && npm run copy:assets",
    "prebuild": "rm -rf ./dist",
    "copy:assets": "mkdir -p dist/assets && cp -r src/assets/* dist/assets/ 2>/dev/null || true"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.11.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
